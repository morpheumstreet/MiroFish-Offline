# Fishtank (Bun) — optional env for local SPA dev
#
# When you run `bun run dev`, the page is served from Bun’s port, not Flask. API calls default to
# same-origin (/api/...), which hits the dev server — so point explicitly at Flask:
BUN_PUBLIC_API_BASE_URL=http://127.0.0.1:5001
#
# Leave unset when using the built SPA served by Flask (Docker or `uv run python run.py`): requests
# use the same host and port as the page automatically.
